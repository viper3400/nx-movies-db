# Copy this file to .env (and optionally .env.local) to configure Nx Movies DB.
# Only check this example into source control; never commit real secrets.

# Database configuration shared by Prisma, movies-service, and tests
DATABASE_URL=mysql://root:password@127.0.0.1:7200/videodb
DATABASE_HOST=127.0.0.1
DATABASE_PORT=7200
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_NAME=videodb

# Backend service host/port
HOST=0.0.0.0
PORT=7100

# GraphQL + UI entrypoints
GRAPHQL_URL=http://127.0.0.1:7100/graphql
GRAPHQL_PROXY_URL=http://127.0.0.1:3000/api/graphql-proxy
APP_BASE_PATH=/movies
APP_VERSION=dev

# Authentication / authorization
JWT_SECRET=dev-jwt-secret-change-me
NEXTAUTH_URL=http://127.0.0.1:3000/api/auth
NEXTAUTH_SECRET=dev-nextauth-secret-change-me
GITHUB_ID=github-client-id
GITHUB_SECRET=github-client-secret
GOOGLE_CLIENT_ID=google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google-client-secret
ALLOWED_USERS=tester@example.com,Tester,1
TEST_MODE=false
NEXT_PUBLIC_TEST_MODE=false
NEXT_PUBLIC_TEST_USERS="tester@example.com,Tester,1"

# Media handling
COVER_IMAGE_PATH=./development-db/coverpics

# TMDB metadata import (server-side movies-ui only)
TMDB_READ_ACCESS_TOKEN=tmdb-v3-read-access-token
TMDB_LANGUAGE=de-DE
TMDB_IMAGE_SIZE=w500

# Build / runtime toggles
NEXT_OUTPUT=standalone
E2E_BASE_URL=http://127.0.0.1:3000/movies
UI_PORT=3000

# Leave CI and NODE_ENV unset locally; CI providers populate them automatically.
