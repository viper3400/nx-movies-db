{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "stabilityDays": 7,
  "constraints": {
    "npm": "11.6.2"
  },
  "packageRules": [
    {
      "description": "Ship security updates immediately",
      "matchUpdateTypes": [
        "security"
      ],
      "stabilityDays": 0
    },
    {
      "description": "Hold minor and patch releases for 3 days",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "stabilityDays": 3
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/^jaxx\\/.*$/"
      ],
      "enabled": false
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "groupName": "g: graphql-apollo",
      "matchPackageNames": [
        "/^@apollo//",
        "/^graphql$/",
        "/^graphql-/",
        "/^@graphql-/",
        "/^@pothos//",
        "/^graphql-yoga$/",
        "/^graphql-scalars$/"
      ]
    },
    {
      "groupName": "g: storybook",
      "separateMajorMinor": true,
      "automerge": false,
      "labels": [
        "deps",
        "storybook"
      ],
      "matchPackageNames": [
        "/^storybook$/",
        "/^@storybook//",
        "/^@chromatic-com/storybook$/",
        "/eslint-plugin-storybook/"
      ]
    },
    {
      "groupName": "g: vite",
      "description": "Group Vite ecosystem dependencies",
      "labels": [
        "deps",
        "vite"
      ],
      "matchPackageNames": [
        "/^vite$/",
        "/^vitest$/",
        "/^vite-plugin-/",
        "/^@vitejs\\//",
        "/^@vitest\\//"
      ]
    },
    {
      "description": "Pin MySQL Docker images to 8.x and block v9 upgrades",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "mysql"
      ],
      "allowedVersions": "<9",
      "matchManagers": [
        "docker-compose"
      ]
    }
  ]
}
